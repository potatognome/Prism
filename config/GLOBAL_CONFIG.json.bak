{
    "PROJECT_NAME": "Prism",
    "PROJECT_FOLDER": "Prism",
    "PROJECT_DESCRIPTION": "Modular, deterministic, colour-aware data-quality orchestrator.",
    "AUTHOR": "Daniel Austin <the.potato.gnome@gmail.com>",
    "VERSION": "0.1.0",
    "MAIN_ENTRY_POINT": "src/prism/interfaces/cli/cli.py",
    "CONFIG_FILES": {
        "GLOBAL_CONFIG": "config/GLOBAL_CONFIG.json",
        "PRISM_CONFIG": "config/config.yaml"
    },
    "LOG_FILES": {
        "SESSION": ".logs/prism/SESSION.log",
        "MASTER": ".logs/prism/MASTER.log",
        "RUNTIME": ".logs/prism/RUNTIME.log",
        "ERROR": ".logs/prism/ERROR.log",
        "TRY": "Prism_TRY.log",
        "INIT": "Prism_INIT.log",
        "FS": "Prism_FS.log",
        "CONFIG_READ": "Prism_CONFIG_READ.log"
    },
    "DISPLAY": {
        "COLOUR_ENABLED": true,
        "LOGGING": "verbose"
    },
    "INFO": {
        "PROJECT_FOLDER": "/Applications/Prism/",
        "PROJECT_DESCRIPTION": "{PROJECT_DESCRIPTION}",
        "AUTHOR": "{AUTHOR}",
        "MAIN_ENTRY_POINT": "Prism.main:main"
    },
    "ROOTS": {
        "WORKSPACE": "C:\\Repository\\Daniel\\dev_local",
        "PROJECT": "C:\\Repository\\Daniel\\dev_local\\Applications\\Prism"
    },
    "ROOT_MODES": {
        "LOG_PATHS": "workspace",
        "TESTS_LOGS": "workspace",
        "CONFIG": "project",
        "TESTS_CONFIG": "project",
        "OUTPUT_DATA": "workspace",
        "INPUT_DATA": "workspace",
        "TESTS_INPUTS": "workspace",
        "TESTS_OUTPUTS": "workspace"
    },
    "PATHS": {
        "LOG_PATHS": ".logs/Prism/",
        "TESTS_LOGS": ".tests_logs/Prism/",
        "CONFIG": "config/",
        "TESTS_CONFIG": ".tests_config/",
        "OUTPUT_DATA": ".projects_data/Prism/",
        "INPUT_DATA": ".projects_data/input_data/",
        "TESTS_INPUTS": ".tests_data/",
        "TESTS_OUTPUTS": ".tests_data/output/"
    },
    "SHARED_CONFIG": {
        "ENABLED": true,
        "PATH": "GLOBAL_SHARED.d/",
        "FILES": {
            "COLOURS": "COLOURS.json",
            "BORDER_PATTERNS": "BORDER_PATTERNS.json",
            "TESTS_OPTIONS": "TESTS_OPTIONS.json",
            "TIME_STAMP_OPTIONS": "TIME_STAMP_OPTIONS.json"
        }
    },
    "ALT_CONFIG": {
        "ENABLED": false,
        "PATH": "",
        "FILES": {
            "COLOURS": "",
            "BORDER_PATTERNS": "",
            "TESTS_OPTIONS": "",
            "TIME_STAMP_OPTIONS": ""
        }
    },
    "LOG_CATEGORIES": {
        "default": [
            "MASTER",
            "SESSION"
        ],
        "runtime": [
            "MASTER",
            "SESSION",
            "RUNTIME"
        ],
        "error": [
            "MASTER",
            "SESSION",
            "ERROR"
        ],
        "init": [
            "MASTER",
            "SESSION",
            "INIT"
        ],
        "fs": [
            "MASTER",
            "SESSION",
            "FS"
        ],
        "config_read": [
            "MASTER",
            "SESSION",
            "CONFIG_READ"
        ],
        "try": [
            "MASTER",
            "SESSION",
            "TRY"
        ],
        "all": [
            "MASTER",
            "SESSION",
            "RUNTIME",
            "TRY",
            "INIT",
            "FS",
            "CONFIG_READ",
            "ERROR"
        ]
    }
}
