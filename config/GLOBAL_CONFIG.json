{
    "PROJECT_NAME": "Prism",
    "PROJECT_FOLDER": "Prism",
    "PROJECT_DESCRIPTION": "Modular, deterministic, colour-aware data-quality orchestrator.",
    "AUTHOR": "Daniel Austin <the.potato.gnome@gmail.com>",
    "VERSION": "0.1.0",
    "MAIN_ENTRY_POINT": "src/prism/interfaces/cli/cli.py",
    "CONFIG_FILES": {
        "GLOBAL_CONFIG":    "config/GLOBAL_CONFIG.json",
        "PRISM_CONFIG":     "config/config.yaml",
        "COLOURS":          "config/GLOBAL_SHARED.d/COLOURS.json",
        "BORDER_PATTERNS":  "config/GLOBAL_SHARED.d/BORDER_PATTERNS.json"
    },
    "LOG_FILES": {
        "SESSION": ".logs/prism/SESSION.log",
        "MASTER":  ".logs/prism/MASTER.log",
        "RUNTIME": ".logs/prism/RUNTIME.log",
        "ERROR":   ".logs/prism/ERROR.log"
    },
    "DISPLAY": {
        "COLOUR_ENABLED": true,
        "LOGGING": "verbose"
    }
}
